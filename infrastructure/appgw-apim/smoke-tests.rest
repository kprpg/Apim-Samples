### 12) Echo API - custom message echo
GET {{baseUrl}}/echo/resource?param1={{echoMessageEncoded}}
Host: {{hostHeader}}
Ocp-Apim-Subscription-Key: {{subscriptionKey}}

> {%
client.test('Echo custom message returns success', function () {
	client.assert([200, 204].includes(response.status), `Unexpected status: ${response.status}`)
})

client.test('Echo response headers contain custom message', function () {
	const originalUrl = response.headers.valueOf('x-original-url') || ''
	const backendUrl = response.headers.valueOf('x-backend-url') || ''
	const expectedPlain = 'Hello Girish I am echoing back to you.'
	const expectedEncoded = 'Hello%20Girish%20I%20am%20echoing%20back%20to%20you.'
	const headerJoined = `${originalUrl} ${backendUrl}`

	client.assert(
		headerJoined.includes(expectedPlain) || headerJoined.includes(expectedEncoded),
		`Expected message not found in echo headers. x-original-url='${originalUrl}', x-backend-url='${backendUrl}'`
	)
})
%}
